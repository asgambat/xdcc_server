# =============================================================
# xdcc-server — Docker Compose environment variables           =
# =============================================================
# Copia questo file in .env e modifica a piacere:
#   cp .env.example .env
# =============================================================

# ── Non-root user (default 1000:1000) ────────────────────────────
# Modifica per far girare il container con un UID/GID specifico
# (es. per allinearti ai permessi del filesystem host).
# UID=1000
# GID=1000

# ── HTTP server ──────────────────────────────────────────────────
# XDCC_HTTP_PORT=8080
# XDCC_HTTP_BIND_ADDRESS=0.0.0.0

# ── Logging ──────────────────────────────────────────────────────
# XDCC_LOGGING_LEVEL=info

# ── Security ─────────────────────────────────────────────────────
# Genera un token random (es. `openssl rand -hex 32`) e decommenta:
# XDCC_SECURITY_ADMIN_TOKEN=
